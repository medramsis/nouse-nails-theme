    "hae_faqs_ACNzbj": {
      "type": "hae-faqs",
      "blocks": {
        "faq_block_jRAPtz": {
          "type": "faq_block",
          "settings": {
            "question": "Will it really not bruise my face?",
            "answer": "<p>ClearVac™ micro-pulse is designed to be gentler than traditional suction. Start on Level 1, keep moving in short glides, and your skin should feel smooth—not sore. Most users see results without any marks.</p>"
          }
        },
        "faq_block_43ptYe": {
          "type": "faq_block",
          "settings": {
            "question": "How long does it take to see results?",
            "answer": "<p>Most users notice smoother texture and fewer visible blackheads after 1-2 uses. For best results, use 2-3x per week. Consistency is key!</p>"
          }
        },
        "faq_block_ABp3fi": {
          "type": "faq_block",
          "settings": {
            "question": "Is it safe for all skin types and ages?",
            "answer": "<p>Yes! PoreLift™ is designed for all skin types. Start on the lowest level if you have sensitive skin. Not recommended for active acne or inflamed areas.</p>"
          }
        },
        "faq_block_QL3tzy": {
          "type": "faq_block",
          "settings": {
            "question": "How do I use PoreLift properly?",
            "answer": "<p>Warm your skin with a hot towel first, apply light gliding motions (don't hover!), and rinse the tip after each use. Start on Level 1 and work your way up as your skin adapts.</p>"
          }
        },
        "faq_block_N3AeaJ": {
          "type": "faq_block",
          "settings": {
            "question": "Can I use this with my skincare products?",
            "answer": "<p>Absolutely! Use PoreLift™ before applying serums and moisturizers for better absorption. Clean, clear pores = better product penetration.</p>"
          }
        }
      },
