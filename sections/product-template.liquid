{% comment %}[/CSS-INLINE]{% endcomment %}]
    {% endcomment %}
    <style>
      .product {
        margin: 0 auto;
        max-width: var(--max-width-small);
        grid-template-columns: 1fr;
        position: relative;
        top: 0;
        gap: var(--grid-padding-main);
        display: block;
      }

      @media screen and (min-width: 940px) {
        .product {
          display: grid;
          grid-template-columns: 1fr 1.35fr;
          gap: calc(2.25 * var(--grid-padding-large));
        }
      }

      .product--no-media {
        max-width: 57rem;
        margin: 0 auto;
      }

      .product__contain {
        padding-top: var(--space-1);
      }

      .shopify-payment-button__button {
        font-family: inherit;
        min-height: 4.6rem;
      }

      .shopify-payment-button__button [role='button'].focused {
        outline: 0.2rem solid rgba(var(--color-foreground), 0.5) !important;
        outline-offset: 0.3rem;
        box-shadow: 0 0 0 0.1rem
            rgba(var(--color-button), var(--alpha-button-border)),
          0 0 0 0.3rem rgb(var(--color-background)),
          0 0 0.5rem 0.4rem rgba(var(--color-foreground), 0.3) !important;
      }

      .shopify-payment-button__button
        [role='button']:focus:not(:focus-visible) {
        outline: 0;
        box-shadow: none !important;
      }

      .shopify-payment-button__button [role='button']:focus-visible {
        outline: 0.2rem solid rgba(var(--color-foreground), 0.5) !important;
        box-shadow: 0 0 0 0.1rem
            rgba(var(--color-button), var(--alpha-button-border)),
          0 0 0 0.3rem rgb(var(--color-background)),
          0 0 0.5rem 0.4rem rgba(var(--color-foreground), 0.3) !important;
      }

      .shopify-payment-button__button--unbranded {
        background-color: rgba(
          var(--color-button),
          var(--alpha-button-background)
        );
        color: rgb(var(--color-button-text));
        font-size: 1.4rem;
        line-height: calc(1 + 0.2 / var(--font-body-scale));
        letter-spacing: 0.07rem;
      }

      .shopify-payment-button__button--unbranded::selection {
        background-color: rgba(var(--color-button-text), 0.3);
      }

      .shopify-payment-button__button--unbranded:hover,
      .shopify-payment-button__button--unbranded:hover:not([disabled]) {
        background-color: rgba(
          var(--color-button),
          var(--alpha-button-background)
        );
      }

      .shopify-payment-button__more-options {
        margin: 1.6rem 0 1rem;
        font-size: 1.2rem;
        line-height: calc(1 + 0.5 / var(--font-body-scale));
        letter-spacing: 0.05rem;
        text-decoration: underline;
        text-underline-offset: 0.3rem;
      }

      .shopify-payment-button__button
        + .shopify-payment-button__button--hidden {
        display: none;
      }

      .product-form {
        display: block;
      }

      .product-form__error-message-wrapper:not([hidden]) {
        display: flex;
        align-items: flex-start;
        font-size: 1.3rem;
        line-height: 1.4;
        letter-spacing: 0.04rem;
        margin-bottom: 1.5rem;
      }

      .product-form__error-message-wrapper .svg-wrapper {
        flex-shrink: 0;
        width: 1.5rem;
        height: 1.5rem;
        margin-right: 0.7rem;
        margin-top: 0.25rem;
      }

      .product-form__input {
        flex: 0 0 100%;
        padding: 0;
        margin: 0 0 var(--space-4) 0;
        min-width: fit-content;
        position: relative;
        border: 1px solid black;
        display: flex;
        flex-direction: column;
        background-color: rgb(var(--color-base-background-1));
        font-size: var(--headline-size-h6) !important;
      }

      .product-form__input select {
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        height: auto;
        height: 3.45rem;
        font-size: var(--headline-size-h6) !important;
      }

      .product-form__input .form__label {
        font-size: var(--text-size-main) !important;
      }

      .product-form__input:hover,
      .product-form__input:focus {
        background-color: rgb(var(--color-base-background-2));
        outline: none;
      }

      variant-selects {
        display: block;
        position: relative;
      }

      .product-form__input .form__label {
        padding-left: 0;
      }

      .product-form__input .select {
        max-width: 100%;
      }

      .product-form__input .svg-wrapper {
        right: 1.5rem;
      }

      .product-form__submit,
      .product-sticky-button__submit {
        position: relative;
      }

      .product-form__submit {
        margin-bottom: 1rem;
        background-color: rgb(var(--color-base-accent-1));
        width: 100%;
        border-color: rgb(var(--color-base-accent-1));
      }

      .product-form__submit .loading__spinner .path {
        stroke: rgb(var(--color-text-2));
      }

      .product-form__submit.loading .product-form__submit-text,
      .product-sticky-button__submit.loading .product-form__submit-text {
        visibility: hidden;
      }

      .product-form__submit:hover,
      .product-form__submit:focus {
        background-color: rgb(var(--color-base-text-2));
        color: rgb(var(--color-base-text-1));
        border-color: rgb(var(--color-base-text-2));
      }

      .product-form__submit[aria-disabled='true']
        + .shopify-payment-button
        .shopify-payment-button__button[disabled],
      .product-form__submit[disabled]
        + .shopify-payment-button
        .shopify-payment-button__button[disabled] {
        cursor: not-allowed;
        opacity: 0.5;
      }

      @media screen and (forced-colors: active) {
        .product-form__submit[aria-disabled='true'] {
          color: Window;
        }
      }

      .product-form__buttons {
        max-width: 44rem;
        text-align: center;
        margin-left: auto;
        margin-right: auto;
        margin-top: var(--space-2);
        margin-bottom: var(--space-1);
      }

      .product-form__quantity-wrapper {
        margin-bottom: var(--space-4);
      }

      .product-form__quantity-wrapper .quantity-wrapper {
        border-radius: var(--border-radius-x-small);
      }

      .product-form__quantity-wrapper .quantity-wrapper .quantity__input {
        min-width: 2rem;
      }

      .accelerated-checkout-button {
        background-color: #ff6100 !important;
        border-radius: var(--border-radius-small);
        color: white;
        font-size: var(--text-size-small);
        font-weight: 400;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: var(--space-2) var(--space-4);
      }

      .shopify-payment-button__more-options {
        color: rgb(var(--color-foreground));
      }

      #more-payment-options-link {
        font-size: var(--text-size-tiny);
        margin-top: var(--space-3);
      }

      .shopify-payment-button__button {
        font-size: 1.5rem;
        letter-spacing: 0.1rem;
      }

      .product__info-container {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
      }

      @media screen and (min-width: 750px) {
        .product__info-container {
          max-width: 27rem;
          margin: auto;
        }
      }

      .product__info-container iframe {
        max-width: 100%;
      }

      .product__description p {
        font-size: var(--text-size-small);
        line-height: var(--text-line-height);
      }

      .product__info-container .product__description,
      .product__info-container .icon-with-text {
        margin: var(--space-2) 0;
        margin-bottom: var(--space-4);
      }

      .product__text {
        margin-bottom: 0;
      }

      a.product__text {
        display: block;
        text-decoration: none;
        color: rgba(var(--color-foreground), 0.75);
      }

      .product__title {
        word-break: break-word;
        margin-bottom: var(--space-3);
        color: rgb(var(--color-accent));
        font-weight: var(--font-weight-normal);
        font-size: var(--headline-size-h2);
      }

      @media screen and (min-width: 750px) {
        .product__title {
          font-size: var(--headline-size-h1);
        }
      }

      .product__accordion .accordion__content {
        padding: 0 1rem;
      }

      .product__type {
