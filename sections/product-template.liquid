      .product-sticky-button__quantity .quantity__button {
        width: 1.5rem;
        flex-shrink: 0;
        font-size: var(--headline-size-h4);
        border: 0;
        background-color: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgb(var(--color-base-text-1));
        padding: 0;
      }

      .product-sticky-button__quantity .quantity__button:first-child {
        margin-left: var(--inputs-border-width);
      }

      .product-sticky-button__quantity .quantity__button:last-child {
