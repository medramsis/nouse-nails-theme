      .product-sticky-button__quantity .quantity__button svg {
        width: 0.75rem;
        pointer-events: none;
      }

      .product-sticky-button__submit {
        flex: 1;
        min-width: 0;
        margin: 0;
        padding: var(--space-4) var(--space-4);
