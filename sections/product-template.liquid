    <style>
      .product-rating {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-1);
        flex-shrink: 0;
      }

      .product-rating__stars {
        display: flex;
        gap: calc(var(--space-1) / 2);
      }

      .product-rating__star {
        width: var(--space-4);
        height: var(--space-4);
        fill: rgb(var(--color-accent));
      }

      .product-rating__star--empty {
        fill: none;
        stroke: rgb(var(--color-accent));
        stroke-width: 1;
      }

      .product-rating__review-count {
        color: rgb(var(--color-text-1));
        font-weight: 500;
      }

      .jdgm-prev-badge {
        display: flex !important;
        flex-direction: column;
        margin-bottom: var(--space-4);
      }

      .jdgm-prev-badge__text {
        text-align: right;
        font-family: var(--text-font-family);
        font-weight: 400;
        font-size: var(--text-size-tiny);
        letter-spacing: var(--text-letter-spacing);
        line-height: var(--text-line-height);
      }

      @media screen and (min-width: 750px) {
        .jdgm-prev-badge__text {
          display: block;
        }
      }
      .jdgm-rev__timestamp {
        color: rgb(var(--color-text-1)) !important;
      }

      .jdgm-rev-widg {
        padding-left: var(--space-6) !important;
        padding-right: var(--space-6) !important;
      }

      .product-rating.product-template__rating .jdgm-preview-badge .jdgm-star {
        color: inherit !important;
        font-size: 1rem !important;
      }

      .jdgm-star.jdgm--on:before,
      .jdgm-star.jdgm--off:before {
        content: '';
        background-color: rgb(var(--color-accent));
        -webkit-mask: url('data:image/svg+xml;base64,')
          no-repeat center;
        mask: url('data:image/svg+xml;base64,')
          no-repeat center;
        -webkit-mask-size: contain;
        mask-size: contain;
        background-repeat: no-repeat;
        width: 13px;
        height: 12px;
        display: inline-block;
      }

      .jdgm-star.jdgm--half:before {
        content: '';
        background-color: rgb(var(--color-accent));
        -webkit-mask: url('data:image/svg+xml;base64,')
          no-repeat center;
        mask: url('data:image/svg+xml;base64,')
          no-repeat center;
        -webkit-mask-size: contain;
        mask-size: contain;
        background-repeat: no-repeat;
        width: 13px;
        height: 12px;
        display: inline-block;
      }

      .jdgm-star.jdgm--off:before {
        content: '';
        background-color: rgba(var(--color-text-1), 0.25);
        -webkit-mask: url('data:image/svg+xml;base64,')
          no-repeat center;
        mask: url('data:image/svg+xml;base64,')
          no-repeat center;
        -webkit-mask-size: contain;
        mask-size: contain;
        background-repeat: no-repeat;
        width: 13px;
        height: 12px;
        display: inline-block;
      }

      .product-rating.product-template__rating .jdgm-prev-badge {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: var(--space-2);
      }

      .product-rating.product-template__rating .jdgm-prev-badge__text {
        font-size: var(--text-size-tiny);
      }

      .product-rating.product-card-grid__rating .jdgm-preview-badge .jdgm-star {
        color: rgb(var(--color-accent)) !important;
        font-size: 0.75rem !important;
      }

      .product-rating.product-card-grid__rating .jdgm-prev-badge__text {
        display: none;
      }

      .product-rating.product-card-grid__rating {
        align-items: flex-end;
        margin-bottom: 0;
        height: 1rem;
      }

      @media screen and (min-width: 750px) {
        .product-rating.product-card-grid__rating .jdgm-prev-badge__text {
          display: block;
        }
      }

      @media screen and (min-width: 750px) {
        .product-rating.product-card-grid__rating {
          margin-top: -2rem;
        }
      }

      .jdgm-paginate__page.jdgm-curt {
        color: rgb(var(--color-text-1)) !important;
      }

      .jdgm-paginate__page {
        color: rgb(var(--color-text-1)) !important;
        font-size: inherit !important;
      }
    </style>
