{% comment %}
  Feature Content Blocks - For alternating image/text sections
{% endcomment %}

<style>
  .feature-blocks-section {
    padding: 60px 20px;
    background: #fff;
  }

  .feature-block {
    max-width: 1200px;
    margin: 0 auto 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .feature-block:last-child {
    margin-bottom: 0;
  }

  .feature-block.reverse {
    direction: rtl;
  }

  .feature-block.reverse > * {
    direction: ltr;
  }

  @media (max-width: 768px) {
    .feature-block {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .feature-block.reverse {
      direction: ltr;
    }
  }

  .feature-image {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .feature-image img,
  .feature-image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feature-content h2 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 16px;
    color: #000;
  }

  .feature-content p {
    font-size: 16px;
    line-height: 1.6;
    color: #666;
  }
</style>

<div class="feature-blocks-section">
  {% for block in section.blocks %}
    <div class="feature-block {% if block.settings.reverse %}reverse{% endif %}">
      <div class="feature-image">
        {% if block.settings.media_type == 'video' and block.settings.video_url != blank %}
          <video autoplay loop muted playsinline>
            <source src="{{ block.settings.video_url }}" type="video/mp4">
          </video>
        {% elsif block.settings.image %}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading }}" loading="lazy">
        {% else %}
          <div style="background: #f5f5f5; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
            <span style="color: #999;">Add Image</span>
          </div>
        {% endif %}
      </div>

      <div class="feature-content">
        <h2>{{ block.settings.heading }}</h2>
        <p>{{ block.settings.description }}</p>
      </div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Feature Content Blocks",
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Daily-Routine Easy."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Rechargeable, rinse-clean tips—warm, glide, rinse, done."
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (MP4)"
        },
        {
          "type": "checkbox",
          "id": "reverse",
          "label": "Reverse Layout (Image on Right)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Content Blocks",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "heading": "Daily-Routine Easy.",
            "description": "Rechargeable, rinse-clean tips—warm, glide, rinse, done.",
            "reverse": false
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Comfort-First Suction",
            "description": "ClearVac™ micro-pulse is designed to be gentle—start on Level 1, glide, don't hover",
            "reverse": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
