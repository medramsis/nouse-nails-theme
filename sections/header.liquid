    }
  }

  .cart-item {
    position: relative;
  }

  .cart-item {
    gap: var(--space-7);
    margin-bottom: var(--space-8);
  }

  @media screen and (min-width: 750px) {
    .cart-item {
      gap: var(--space-5);
    }
  }

  .cart-item:last-child {
