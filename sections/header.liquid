  }

  .cart__warnings .cart__empty-text {
    font-family: var(--primary-font-family);
    font-size: var(--headline-size-h1);
    margin: 0 0 var(--space-6);
  }

  .cart__warnings .button {
    margin-bottom: var(--space-6);
  }

  .cart__login-title {
