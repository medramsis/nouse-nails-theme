    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .cart-item__details {
    font-size: var(--text-size-base);
    line-height: calc(1 + 0.4 / var(--font-body-scale));
  }

  .cart-item__details > * {
    margin: 0;
    max-width: 30rem;
  }

  .cart-item__details > * + * {
    margin-top: var(--space-2);
  }

  .cart-item__name {
    text-decoration: none;
