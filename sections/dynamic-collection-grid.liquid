<link
  rel='stylesheet'
  href='{{ 'collection.css' | asset_url }}'
  media='print'
  onload="this.media='all'"
>
{{ 'template-dynamic-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{% comment %}[CSS-INLINE: product-card-grid.css | <link
  rel='stylesheet'
  href='{{ 'product-card-grid.css' | asset_url }}'
  inline-css='true'
>]{% endcomment %}
<style>
.product-card-grid{display:block;text-decoration:none;color:inherit;transition:transform .3s;overflow:hidden}.product-card-grid__link{position:relative;text-decoration:none;display:block}.product-card-grid__image-container{position:relative;width:100%;padding-bottom:100%;overflow:hidden;margin-bottom:var(--space-2);border:1px dotted transparent}.product-card-grid__image{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;transition:transform .3s}.product-card-grid__image--hover{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .3s}.product-card-grid:hover .product-card-grid__image--hover{opacity:1}.product-card-grid__image-link{position:absolute;top:0;left:0;width:100%;height:100%;z-index:1;opacity:0}.product-card-grid__content{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;flex-direction:column;gap:var(--space-4)}@media screen and (min-width:750px){.product-card-grid__image-container{margin-bottom:var(--space-4)}.product-card-grid__content{flex-direction:row}}.product-card-grid__details{width:100%;min-width:0}.product-card-grid__subtitle{margin-bottom:var(--space-2)}.product-card-grid__title{font-size:var(--text-size-small);margin-bottom:0}@media screen and (min-width:750px){.product-card-grid__title{font-size:var(--headline-size-h5);max-width:73%}}.product-card-grid__price{font-weight:700}.product-card-grid__vendor{color:rgba(var(--color-text-1),.6);margin-bottom:var(--space-1)}.product-card-grid__price-wrapper{margin-top:0;display:flex;flex-direction:row;justify-content:space-between;font-size:var(--text-size-small)}.product-card-grid__sold-out-badge{display:none}.product-card-grid--sold-out .product-card-grid__sold-out-badge{display:block;position:absolute;right:var(--space-2);left:auto;top:var(--space-3);z-index:1;width:4.75rem;height:4.75rem;display:flex;justify-content:center;align-items:center}@media screen and (min-width:750px){.product-card-grid__price-wrapper{font-size:var(--headline-size-h5)}.product-card-grid--sold-out .product-card-grid__sold-out-badge{width:5rem;height:5rem}}.product-card-grid__sold-out-badge__text{position:absolute;left:0;right:0;margin:auto;top:.5rem;bottom:0;z-index:1;width:2rem;height:2.5rem;text-align:center;text-transform:uppercase;display:block;line-height:1;font-size:var(--text-size-tiny)}@media screen and (min-width:750px){.product-card-grid__sold-out-badge__text{top:.25rem;bottom:0;z-index:1;width:2.5rem;height:2.5rem}}.klaviyo-bis-trigger-collection{margin-top:var(--space-3);padding:var(--space-2) var(--space-1);font-size:.6rem;max-width:14rem;background-color:rgb(var(--color-base-accent-1));color:rgb(var(--color-text-1-1));border:1px solid rgb(var(--color-button-primary-border));border-radius:100vw;text-align:center;text-transform:uppercase;font-weight:700;letter-spacing:.05em;text-decoration:none;cursor:pointer;transition:all .3s var(--default-easing);position:absolute;bottom:var(--space-3);width:98%;left:0;right:0;margin:auto;z-index:1;display:block}@media screen and (min-width:750px){.klaviyo-bis-trigger-collection{font-size:var(--text-size-tiny);border:2px solid rgb(var(--color-button-primary-border));width:100%;padding:var(--space-3) var(--space-2);font-size:var(--text-size-tiny);max-width:17rem;margin:auto}}.klaviyo-bis-trigger-collection:hover{background-color:rgb(var(--color-text-1));border-color:rgb(var(--color-text-1));color:rgb(var(--color-background))}
</style>
{% comment %}[/CSS-INLINE]{% endcomment %}
{{ 'component-video.css' | asset_url | stylesheet_tag }}

<!-- Loop through and display blocks -->
{% case section.settings.grid %}
  {% when 2 %}
    {%- assign grid_class = 'grid-6' -%}
  {% when 3 %}
    {%- assign grid_class = 'grid-3' -%}
  {% when 4 %}
    {%- assign grid_class = 'grid-4' -%}
  {% when 5 %}
    {%- assign grid_class = 'grid-5' -%}
{% endcase %}

<section class='dynamic-collection-grid color-{{ section.settings.color_scheme }}'>
  <div class='container-main   {{ section.settings.section_padding_top }} {{ section.settings.section_padding_bottom }}'>
    {% if section.settings.hide_title != true %}
      {% if section.settings.title != blank %}
        <h1 class='dynamic-collection-grid_heading  headline-style-h1'>
          {{ section.settings.title | escape }}
        </h1>
      {% else %}
        <h1 class='dynamic-collection-grid_heading  headline-style-h1'>
          {{ collection.title | escape }}
        </h1>
      {% endif %}
    {% endif %}
    {% if section.settings.richtext_content != blank %}
      <div class='dynamic-collection-grid__richtext rte'>
        {% if section.settings.richtext_content != blank %}
          {{ section.settings.richtext_content }}
        {% else %}
          {{ collection.description }}
        {% endif %}
      </div>
    {% endif %}
    <ul class='dynamic-collection-grid grid {{ grid_class }} grid-gap-md'>
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'product' %}
            <li class='dynamic-collection-grid__product'>
              {% render 'product-card-grid',
                product: block.settings.product,
                show_vendor: true,
                show_rating: true,
                show_quick_add: section.settings.enable_quick_add
              %}
            </li>
          {% when 'video_embed' %}
            <li class='dynamic-collection-grid__video {% if block.settings.media_aspect_ratio == '16/9' or block.settings.media_aspect_ratio == '64/41' %}col-2{% endif %}'>
              {% render 'video-with-aspect-ratio',
                video: block.settings.video,
                aspect_ratio: block.settings.media_aspect_ratio,
                autoplay: block.settings.autoplay,
                loop: block.settings.autoplay,
                muted: true,
                controls: block.settings.controls,
                motion_reduce: true
              %}
            </li>
          {% when 'image' %}
            <li class='dynamic-collection-grid__image {% if block.settings.media_aspect_ratio == '16/9' or block.settings.media_aspect_ratio == '64/41' %}col-2{% endif %}'>
              {% if block.settings.media_aspect_ratio == '16/9'
                or block.settings.media_aspect_ratio == '64/41'
              %}
                {% render 'image-with-aspect-ratio',
                  image: block.settings.image,
                  aspect_ratio: block.settings.media_aspect_ratio,
                  alt: block.settings.image.alt,
                  sizes: '(min-width: 940px) 40vw, (min-width: 750px) 80vw, 100vw',
                  widths: '165,360,533,720,940,1066'
                %}

              {% else %}
                {% render 'image-with-aspect-ratio',
                  image: block.settings.image,
                  aspect_ratio: block.settings.media_aspect_ratio,
                  alt: block.settings.image.alt,
                  sizes: '(min-width: 940px) 33vw, (min-width: 750px) 33vw, 100vw',
                  widths: '165,360,533,720,940,1066'
                %}
              {% endif %}
            </li>
        {% endcase %}
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Dynamic Collection Grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "If left blank, the collection title will be used unless hidden"
    },
    {
      "type": "checkbox",
      "id": "hide_title",
      "label": "Hide title",
      "default": false
    },
    {
      "type": "richtext",
      "id": "richtext_content",
      "label": "Rich text",
      "info": "Optional content displayed below the title"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "options": [
        {
          "value": "section-padding-top-none",
          "label": "None"
        },
        {
          "value": "section-padding-top-x-small",
          "label": "Extra Small"
        },
        {
          "value": "section-padding-top-small",
          "label": "Small"
        },
        {
          "value": "section-padding-top-main",
          "label": "Medium"
        },
        {
          "value": "section-padding-top-large",
          "label": "Large"
        }
      ],
      "default": "section-padding-top-small"
    },
    {
      "type": "select",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "options": [
        {
          "value": "section-padding-bottom-none",
          "label": "None"
        },
        {
          "value": "section-padding-bottom-x-small",
          "label": "Extra Small"
        },
        {
          "value": "section-padding-bottom-small",
          "label": "Small"
        },
        {
          "value": "section-padding-bottom-main",
          "label": "Medium"
        },
        {
          "value": "section-padding-bottom-large",
          "label": "Large"
        }
      ],
      "default": "section-padding-bottom-small"
    }
  ],
  "blocks": [
    {
      "name": "Product",
      "type": "product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    },
    {
      "name": "Video Embed",
      "type": "video_embed",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "A Shopify-hosted video"
        },
        {
          "type": "header",
          "content": "Video Settings"
        },
        {
          "type": "radio",
          "id": "autoplay",
          "label": "Autoplay",
          "options": [
            {
              "value": "false",
              "label": "Off"
            },
            {
              "value": "true",
              "label": "On"
            }
          ],
          "default": "true"
        },
        {
          "type": "select",
          "id": "media_aspect_ratio",
          "label": "Media aspect ratio",
          "options": [
            {
              "value": "16/9",
              "label": "16:9 (Landscape)"
            },
            {
              "value": "64/41",
              "label": "4:3 (Portrait Horizontal)"
            },
            {
              "value": "1/1",
              "label": "1:1 (Square)"
            },
            {
              "value": "3/4",
              "label": "3:4 (Portrait)"
            }
          ],
          "default": "1/1"
        },
        {
          "type": "checkbox",
          "id": "controls",
          "label": "Video Controls",
          "default": false
        }
      ]
    },
    {
      "name": "Image",
      "type": "image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image or GIF"
        },
        {
          "type": "radio",
          "id": "art_direction",
          "label": "Image Art Direction",
          "options": [
            {
              "value": "portrait",
              "label": "Portrait"
            },
            {
              "value": "wide",
              "label": "Wide"
            }
          ],
          "default": "portrait"
        },
        {
          "type": "select",
          "id": "media_aspect_ratio",
          "label": "Media aspect ratio",
          "options": [
            {
              "value": "16/9",
              "label": "16:9 (Landscape)"
            },
            {
              "value": "64/41",
              "label": "4:3 (Portrait Horizontal)"
            },
            {
              "value": "1/1",
              "label": "1:1 (Square)"
            },
            {
              "value": "3/4",
              "label": "3:4 (Portrait)"
            }
          ],
          "default": "3/4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dynamic Collection Grid",
      "category": "Collection & Catalog",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "image"
        },
        {
          "type": "video_embed"
        }
      ]
    }
  ]
}
{% endschema %}
